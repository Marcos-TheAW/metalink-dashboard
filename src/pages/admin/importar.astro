---
import Layout from '../../layouts/Layout.astro';
import {
  processarImportacaoAcoesXlsx,
  processarImportacaoPedidosXlsx,
  type ResultadoImportacaoAcoes,
  type ResultadoImportacaoPedidos
} from '../../lib/importacao';
import { processarImportacaoSitesXlsx, type ResultadoImportacaoSites } from '../../lib/importacaoSites';

const usuario = Astro.locals.usuario;

// Checagem redundante: o middleware já retorna 403 para não-admins em /admin.
if (usuario.papel !== 'admin') {
  return new Response('Acesso restrito a administradores.', { status: 403 });
}

let resultadoSites: ResultadoImportacaoSites | null = null;
let erroSites: string | null = null;
let resultadoPedidos: ResultadoImportacaoPedidos | null = null;
let erroPedidos: string | null = null;
let resultadoAcoes: ResultadoImportacaoAcoes | null = null;
let erroAcoes: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const tipo = String(form.get('tipo') ?? '');

  if (tipo === 'sites') {
    try {
      const arquivo = form.get('arquivo_sites');
      if (!(arquivo instanceof File) || arquivo.size === 0) {
        erroSites = 'Selecione um arquivo .xlsx antes de enviar.';
      } else {
        const buffer = await arquivo.arrayBuffer();
        resultadoSites = await processarImportacaoSitesXlsx(buffer, usuario.id);
      }
    } catch (e) {
      erroSites = e instanceof Error ? e.message : 'Falha ao processar o arquivo.';
    }
  } else if (tipo === 'pedidos') {
    try {
      const arquivo = form.get('arquivo_pedidos');
      if (!(arquivo instanceof File) || arquivo.size === 0) {
        erroPedidos = 'Selecione um arquivo .xlsx antes de enviar.';
      } else {
        const buffer = await arquivo.arrayBuffer();
        resultadoPedidos = await processarImportacaoPedidosXlsx(buffer, usuario.id);
      }
    } catch (e) {
      erroPedidos = e instanceof Error ? e.message : 'Falha ao processar o arquivo.';
    }
  } else if (tipo === 'acoes') {
    try {
      const arquivo = form.get('arquivo_acoes');
      if (!(arquivo instanceof File) || arquivo.size === 0) {
        erroAcoes = 'Selecione um arquivo .xlsx antes de enviar.';
      } else {
        const buffer = await arquivo.arrayBuffer();
        resultadoAcoes = await processarImportacaoAcoesXlsx(buffer, usuario.id);
      }
    } catch (e) {
      erroAcoes = e instanceof Error ? e.message : 'Falha ao processar o arquivo.';
    }
  }
}
---

<Layout title="Importar" usuario={usuario}>
  <h1 class="mb-6">Importar</h1>

  <div class="flex flex-col gap-8">
    <section class="card max-w-2xl">
      <h2>Registro de Sites (Prospecção)</h2>
      <p class="mt-2 text-sm text-slate-600">
        Envie um arquivo <code class="rounded bg-slate-100 px-1 py-0.5">.xlsx</code> com os novos contatos
        de sites parceiros. Baixe o modelo abaixo, preencha os dados e faça o upload — os nomes das
        colunas precisam ficar como estão no modelo (a ordem não importa, mas não renomeie os cabeçalhos).
      </p>
      <a href="/api/prospeccao/sites/modelo" class="btn-secondary mt-3 inline-flex">Baixar modelo .xlsx</a>

      <form method="post" enctype="multipart/form-data" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
        <input type="hidden" name="tipo" value="sites" />
        <div class="flex-1">
          <label for="arquivo_sites">Arquivo .xlsx</label>
          <input type="file" id="arquivo_sites" name="arquivo_sites" accept=".xlsx" required />
        </div>
        <button type="submit" class="btn-primary">Importar sites</button>
      </form>

      {
        erroSites && (
          <div class="mt-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            {erroSites}
          </div>
        )
      }

      {
        resultadoSites && (
          <div class="mt-4 flex flex-col gap-4">
            <div class="rounded-md border border-brand-500 bg-brand-500/10 px-4 py-3 text-sm text-white">
              <strong>{resultadoSites.inseridos}</strong> site(s) importado(s), {resultadoSites.ignorados.length} linha(s) ignorada(s).
            </div>
            {resultadoSites.ignorados.length > 0 && (
              <div class="overflow-x-auto">
                <table>
                  <thead>
                    <tr>
                      <th>Linha no arquivo</th>
                      <th>Motivo</th>
                    </tr>
                  </thead>
                  <tbody>
                    {resultadoSites.ignorados.map((item) => (
                      <tr>
                        <td>{item.linha}</td>
                        <td>{item.motivo}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )
      }
    </section>

    <section class="card max-w-2xl">
      <h2>Pedidos</h2>
      <p class="mt-2 text-sm text-slate-600">
        Envie um arquivo <code class="rounded bg-slate-100 px-1 py-0.5">.xlsx</code> com os pedidos.
        Baixe o modelo abaixo, preencha os dados e faça o upload — os nomes das colunas precisam ficar
        como estão no modelo (a ordem não importa, mas não renomeie os cabeçalhos). Clientes citados que
        ainda não existem são cadastrados automaticamente.
      </p>
      <a href="/api/admin/pedidos/modelo" class="btn-secondary mt-3 inline-flex">Baixar modelo .xlsx</a>

      <form method="post" enctype="multipart/form-data" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
        <input type="hidden" name="tipo" value="pedidos" />
        <div class="flex-1">
          <label for="arquivo_pedidos">Arquivo .xlsx</label>
          <input type="file" id="arquivo_pedidos" name="arquivo_pedidos" accept=".xlsx" required />
        </div>
        <button type="submit" class="btn-primary">Importar pedidos</button>
      </form>

      {
        erroPedidos && (
          <div class="mt-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            {erroPedidos}
          </div>
        )
      }

      {
        resultadoPedidos && (
          <div class="mt-4 flex flex-col gap-4">
            <div class="rounded-md border border-brand-500 bg-brand-500/10 px-4 py-3 text-sm text-white">
              <strong>{resultadoPedidos.inseridos}</strong> pedido(s) importado(s), {resultadoPedidos.ignorados.length} linha(s) ignorada(s).
            </div>
            {resultadoPedidos.ignorados.length > 0 && (
              <div class="overflow-x-auto">
                <table>
                  <thead>
                    <tr>
                      <th>Linha no arquivo</th>
                      <th>Motivo</th>
                    </tr>
                  </thead>
                  <tbody>
                    {resultadoPedidos.ignorados.map((item) => (
                      <tr>
                        <td>{item.linha}</td>
                        <td>{item.motivo}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )
      }
    </section>

    <section class="card max-w-2xl">
      <h2>Ações Comerciais (Atividades Proativas)</h2>
      <p class="mt-2 text-sm text-slate-600">
        Envie um arquivo <code class="rounded bg-slate-100 px-1 py-0.5">.xlsx</code> com as ações
        comerciais (follow-up, proposta, upsell, prospecção...). Baixe o modelo abaixo, preencha os
        dados e faça o upload — os nomes das colunas precisam ficar como estão no modelo (a ordem não
        importa, mas não renomeie os cabeçalhos). Clientes/prospects citados que ainda não existem são
        cadastrados automaticamente.
      </p>
      <a href="/api/admin/acoes/modelo" class="btn-secondary mt-3 inline-flex">Baixar modelo .xlsx</a>

      <form method="post" enctype="multipart/form-data" class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
        <input type="hidden" name="tipo" value="acoes" />
        <div class="flex-1">
          <label for="arquivo_acoes">Arquivo .xlsx</label>
          <input type="file" id="arquivo_acoes" name="arquivo_acoes" accept=".xlsx" required />
        </div>
        <button type="submit" class="btn-primary">Importar ações</button>
      </form>

      {
        erroAcoes && (
          <div class="mt-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            {erroAcoes}
          </div>
        )
      }

      {
        resultadoAcoes && (
          <div class="mt-4 flex flex-col gap-4">
            <div class="rounded-md border border-brand-500 bg-brand-500/10 px-4 py-3 text-sm text-white">
              <strong>{resultadoAcoes.inseridos}</strong> ação(ões) importada(s), {resultadoAcoes.ignorados.length} linha(s) ignorada(s).
            </div>
            {resultadoAcoes.ignorados.length > 0 && (
              <div class="overflow-x-auto">
                <table>
                  <thead>
                    <tr>
                      <th>Linha no arquivo</th>
                      <th>Motivo</th>
                    </tr>
                  </thead>
                  <tbody>
                    {resultadoAcoes.ignorados.map((item) => (
                      <tr>
                        <td>{item.linha}</td>
                        <td>{item.motivo}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )
      }
    </section>
  </div>
</Layout>
