---
interface Props {
  label: string;
  value: string;
  hint?: string;
}

const { label, value, hint } = Astro.props;
---

<div class="card">
  <div class="text-xs font-medium uppercase tracking-wide text-slate-500">{label}</div>
  <div class="mt-2 text-2xl font-semibold text-slate-900">{value}</div>
  {hint && <div class="mt-1 text-xs text-slate-500">{hint}</div>}
</div>
