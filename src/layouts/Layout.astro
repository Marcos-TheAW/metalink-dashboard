---
import '../styles/global.css';
import type { Usuario } from '../lib/types';

interface Props {
  title: string;
  usuario: Usuario;
}

const { title, usuario } = Astro.props;

const gruposNav = [
  {
    label: 'Comercial',
    links: [
      { href: '/', label: 'Dashboard' },
      { href: '/pedidos', label: 'Pedidos' },
      { href: '/comercial', label: 'Ações Comerciais' },
      { href: '/clientes', label: 'Clientes' }
    ]
  },
  {
    label: 'Prospecção de Sites',
    links: [
      { href: '/prospeccao', label: 'Overview' },
      { href: '/prospeccao/sites', label: 'Registro de Sites' },
      { href: '/prospeccao/painel-semanal', label: 'Painel Semanal' },
      { href: '/prospeccao/tabela-precos', label: 'Tabela de Preços' }
    ]
  }
];

const linksAdmin = [
  { href: '/admin/importar', label: 'Importar' },
  { href: '/admin/exportar', label: 'Exportar' },
  { href: '/admin/usuarios', label: 'Usuários' }
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/favicon-192.png" />
    <title>{title} · Metalink Dashboard</title>
  </head>
  <body>
    <div class="min-h-screen">
      <header class="border-b border-slate-300 bg-slate-100">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
          <nav class="flex gap-1">
            {
              gruposNav.map((grupo) => (
                <div class="group relative">
                  <button
                    type="button"
                    class="cursor-pointer rounded-md px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-200 hover:text-white"
                  >
                    {grupo.label}
                  </button>
                  <div class="absolute left-0 z-10 mt-1 hidden min-w-[12rem] rounded-md bg-[#2a2e51] py-1 shadow-lg group-hover:block group-focus-within:block">
                    {
                      grupo.links.map((link) => (
                        <a href={link.href} class="block px-3 py-1.5 text-sm text-white hover:bg-brand-blue">
                          {link.label}
                        </a>
                      ))
                    }
                  </div>
                </div>
              ))
            }
            {
              usuario.papel === 'admin' && (
                <div class="group relative">
                  <button
                    type="button"
                    class="cursor-pointer rounded-md px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-200 hover:text-white"
                  >
                    Admin
                  </button>
                  <div class="absolute left-0 z-10 mt-1 hidden min-w-[10rem] rounded-md bg-[#2a2e51] py-1 shadow-lg group-hover:block group-focus-within:block">
                    {
                      linksAdmin.map((link) => (
                        <a href={link.href} class="block px-3 py-1.5 text-sm text-white hover:bg-brand-blue">
                          {link.label}
                        </a>
                      ))
                    }
                  </div>
                </div>
              )
            }
          </nav>
          <div class="flex items-center gap-4">
            <div class="text-right text-xs text-slate-500">
              <a href="/minha-conta" class="font-medium text-slate-700 hover:text-white hover:underline">
                {usuario.nome}
              </a>
              <div>{usuario.papel === 'admin' ? 'Administrador' : 'Colaborador'}</div>
            </div>
            <form method="post" action="/api/logout">
              <button type="submit" class="text-xs font-medium text-slate-500 hover:text-white hover:underline">
                Sair
              </button>
            </form>
            <img src="/logo.png" alt="Metalink" class="h-8 w-auto" />
          </div>
        </div>
      </header>
      <main class="mx-auto max-w-6xl px-6 py-8">
        <slot />
      </main>
    </div>
  </body>
</html>
