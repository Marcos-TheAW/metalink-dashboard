{
  "name": "metalink-dashboard",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "astro build && wrangler deploy",
    "db:migrate:local": "bun run scripts/aplicar-migrations.ts",
    "db:migrate:remote": "bun run scripts/aplicar-migrations.ts --remote",
    "import:planilha": "bun run scripts/importar-planilha.ts",
    "import:registro-sites": "bun run scripts/importar-registro-sites.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "tailwindcss": "^4.3.2",
    "wrangler": "^4.110.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/node": "^26.1.1",
    "typescript": "^5.7.0"
  }
}
